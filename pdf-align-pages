#!/usr/bin/env python3
"""Align PDF pages by centering detected rectangular frames."""

import sys
import os
import cv2
import numpy as np
from pdf2image import convert_from_path
from PIL import Image


def find_content_rect(image, margin_percent=2):
    """Detect main content block bounding box."""
    gray = cv2.cvtColor(np.array(image), cv2.COLOR_RGB2GRAY)
    h, w = gray.shape

    # Margin to ignore scanner/edge artifacts
    margin_x = int(w * margin_percent / 100)
    margin_y = int(h * margin_percent / 100)

    # Threshold to find non-white content
    _, binary = cv2.threshold(gray, 230, 255, cv2.THRESH_BINARY_INV)

    # Mask out margins
    binary[:margin_y, :] = 0
    binary[-margin_y:, :] = 0
    binary[:, :margin_x] = 0
    binary[:, -margin_x:] = 0

    # Aggressive morphological closing to merge text into blocks
    kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (50, 50))
    binary = cv2.morphologyEx(binary, cv2.MORPH_CLOSE, kernel)

    # Find connected components and use the largest one (main text block)
    num_labels, labels, stats, centroids = cv2.connectedComponentsWithStats(binary)

    if num_labels <= 1:
        return None

    # Skip background (label 0), find largest component
    largest_label = 1 + np.argmax(stats[1:, cv2.CC_STAT_AREA])
    x = stats[largest_label, cv2.CC_STAT_LEFT]
    y = stats[largest_label, cv2.CC_STAT_TOP]
    w = stats[largest_label, cv2.CC_STAT_WIDTH]
    h = stats[largest_label, cv2.CC_STAT_HEIGHT]

    return (x, y, w, h)

def align_pecha_pages(input_pdf, output_pdf):
    pages = convert_from_path(input_pdf, dpi=300)
    page_width, page_height = pages[0].size
    
    # Detect content bounds on each page
    rects = [find_content_rect(p) for p in pages]

    # Target: center of page
    target_cx = page_width / 2
    target_cy = page_height / 2

    aligned = []
    for i, (page, rect) in enumerate(zip(pages, rects), 1):
        print(f"  Page {i}/{len(pages)}: ", end="")
        if rect:
            x, y, w, h = rect
            content_cx = x + w / 2
            content_cy = y + h / 2
            shift_x = int(target_cx - content_cx)
            shift_y = int(target_cy - content_cy)
            print(f"shift ({shift_x:+d}, {shift_y:+d})")

            img_array = np.array(page)
            M = np.float32([[1, 0, shift_x], [0, 1, shift_y]])
            shifted = cv2.warpAffine(img_array, M, (page_width, page_height),
                                     borderValue=(255, 255, 255))
            aligned.append(Image.fromarray(shifted))
        else:
            print("no content detected, skipping")
            aligned.append(page)
    
    aligned[0].save(output_pdf, save_all=True, append_images=aligned[1:], 
                    resolution=300, optimize=True)

def main():
    if len(sys.argv) < 2:
        print(f"Usage: {os.path.basename(sys.argv[0])} <input.pdf> [output.pdf]")
        sys.exit(1)

    input_pdf = sys.argv[1]

    if not os.path.exists(input_pdf):
        print(f"Error: File not found: {input_pdf}")
        sys.exit(1)

    if len(sys.argv) >= 3:
        output_pdf = sys.argv[2]
    else:
        base, ext = os.path.splitext(input_pdf)
        output_pdf = f"{base}_aligned{ext}"

    print(f"Aligning pages: {input_pdf} → {output_pdf}")
    align_pecha_pages(input_pdf, output_pdf)
    print(f"Done: {output_pdf}")


if __name__ == "__main__":
    main()